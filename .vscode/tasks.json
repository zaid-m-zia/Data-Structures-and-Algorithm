{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile and run Java",
            "type": "shell",
            "command": "/bin/zsh",
            "args": [
                "-c",
                "cd '${fileDirname}' && javac '${fileBasename}' && java '${fileBasenameNoExtension}' < input.txt > output.txt"
            ],
            "presentation": {
                "reveal": "always"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}